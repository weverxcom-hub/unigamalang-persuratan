// Sistem Manajemen Persuratan Universitas Gajayana (unigamalang)
//
// Prisma schema. Target: Postgres (Neon / Supabase free tier).
//
//   DATABASE_URL – pooled connection (runtime, via pgbouncer)
//   DIRECT_URL   – direct connection (prisma migrate)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -------------------------------------------------------------------------
//  Enums
// -------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  ADMIN_UNIT
  USER
}

enum Direction {
  OUTGOING
  INCOMING
}

enum ArchiveStatus {
  DRAFT
  PENDING // USER draft waiting for admin approval
  PENDING_PROOF // Number allocated, awaiting proof upload
  APPROVED
  ISSUED
}

enum DispositionStatus {
  PENDING
  ACKNOWLEDGED
  COMPLETED
  REJECTED
}

enum AuditAction {
  CREATE
  UPDATE
  UPLOAD
  DELETE
  RESTORE
  LOGIN
  LOGIN_FAILED
  DISPOSITION_CREATE
  DISPOSITION_UPDATE
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

// -------------------------------------------------------------------------
//  Core entities
// -------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(USER)
  unitId       String?
  unit         Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  // Soft-delete sentinel. When non-null, account is deactivated: cannot
  // log in and is hidden from list endpoints by default.
  deletedAt    DateTime?

  archives             Archive[]
  dispositionsSent     Disposition[] @relation("DispositionFrom")
  dispositionsReceived Disposition[] @relation("DispositionTo")
  auditLogs            AuditLog[]

  @@index([unitId])
  @@index([deletedAt])
}

model Unit {
  id             String    @id @default(cuid())
  code           String    @unique // e.g. "UNIGA", "YAS"
  name           String
  // Template for numbering. Supported placeholders:
  //   [NO]          zero-padded sequence (3 digits)
  //   [UNIT_CODE]   this unit's code
  //   [TYPE_CODE]   selected letter type code
  //   [ROMAN_MONTH] current month in Roman numerals (I..XII)
  //   [MONTH]       current month (1..12)
  //   [YEAR]        current 4-digit year
  formatTemplate String    @default("[NO]/[UNIT_CODE]/[TYPE_CODE]/[ROMAN_MONTH]/[YEAR]")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // Soft delete — never hard-delete (Archive.unit / User.unit / sequences
  // reference this row).
  deletedAt      DateTime?

  users        User[]
  archives     Archive[]
  sequences    NumberingSequence[]
  dispositions Disposition[]

  @@index([deletedAt])
}

model LetterType {
  id        String    @id @default(cuid())
  code      String    @unique // e.g. "SK", "ST"
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Soft delete — never hard-delete (Archive.letterType references this
  // row).
  deletedAt DateTime?

  archives Archive[]

  @@index([deletedAt])
}

/// Per-unit per-year sequence counter. Tracked ONLY by (unitId, year) to
/// prevent gaps in the sequence when a unit uses multiple letter types in
/// the same year, and to reset automatically on 1 January.
model NumberingSequence {
  id        String   @id @default(cuid())
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  year      Int
  last      Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([unitId, year])
  @@index([unitId, year])
}

model Archive {
  id             String        @id @default(cuid())
  number         String // e.g. "001/UNIGA/SK/IV/2026"
  date           DateTime      @default(now())
  subject        String
  recipient      String // internal recipient / tujuan (OUTGOING) or internal receiver (INCOMING)
  externalSender String? // free-text sender for INCOMING letters
  direction      Direction     @default(OUTGOING)
  status         ArchiveStatus @default(PENDING_PROOF)

  unitId         String
  unit           Unit       @relation(fields: [unitId], references: [id], onDelete: Restrict)
  unitCode       String // denormalised for fast display
  letterTypeId   String
  letterType     LetterType @relation(fields: [letterTypeId], references: [id], onDelete: Restrict)
  letterTypeCode String

  sequenceNumber Int @default(0)

  fileUrl      String? // Storage URL (Google Drive webViewLink, or legacy Vercel Blob URL)
  blobPathname String? // Vercel Blob pathname (legacy, for cleanup of old Blob assets)
  gdriveFileId String? // Google Drive file ID, for permission management & deletion
  fileName     String?
  fileDataUrl  String? // legacy inline base64; superseded by fileUrl

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft delete — never hard-delete. Queries should filter deletedAt: null.
  deletedAt   DateTime?

  dispositions Disposition[]
  auditLogs    AuditLog[]

  @@index([unitId])
  @@index([letterTypeId])
  @@index([createdById])
  @@index([deletedAt])
  @@index([direction])
  @@index([status])
  @@index([date])
  @@index([number])
}

model Disposition {
  id           String            @id @default(cuid())
  archiveId    String
  archive      Archive           @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  fromUserId   String
  fromUser     User              @relation("DispositionFrom", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUserId     String?
  toUser       User?             @relation("DispositionTo", fields: [toUserId], references: [id], onDelete: SetNull)
  toUnitId     String?
  toUnit       Unit?             @relation(fields: [toUnitId], references: [id], onDelete: SetNull)
  instructions String
  dueDate      DateTime?
  status       DispositionStatus @default(PENDING)
  note         String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  acknowledgedAt DateTime?
  completedAt    DateTime?

  @@index([archiveId])
  @@index([toUserId])
  @@index([toUnitId])
  @@index([status])
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  actorId    String?
  actor      User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail String? // denormalised for post-deletion traceability
  targetType String // "Archive" | "Disposition" | "User" | "Unit" | "LetterType" | "Auth"
  targetId   String?
  archiveId  String?
  archive    Archive?    @relation(fields: [archiveId], references: [id], onDelete: SetNull)
  metadata   Json? // free-form diff / payload
  ip         String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([archiveId])
  @@index([createdAt])
}

/// Outbound webhook delivery log. Every letter-create event enqueues a row
/// here; the app delivers to `N8N_WEBHOOK_URL` and records success/failure.
model WebhookDelivery {
  id             String                @id @default(cuid())
  event          String // e.g. "archive.created", "disposition.created"
  archiveId      String?
  targetUrl      String
  payload        Json
  signature      String // HMAC-SHA256 of payload with WEBHOOK_SIGNING_SECRET
  status         WebhookDeliveryStatus @default(PENDING)
  attempts       Int                   @default(0)
  lastError      String?
  responseStatus Int?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([status])
  @@index([archiveId])
  @@index([createdAt])
}
