# ---------------------------------------------------------------------------
# Sistem Manajemen Persuratan Universitas Gajayana (unigamalang)
#
# Copy to `.env.local` for dev, or set each var in the Vercel project settings.
# Only AUTH_SECRET + DATABASE_URL + DIRECT_URL are REQUIRED. Everything else
# gracefully degrades when left blank.
# ---------------------------------------------------------------------------

# REQUIRED — session signing key (>=32 chars)
AUTH_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# REQUIRED — Neon Postgres (or any Postgres). Pooled URL for serverless runtime,
# direct URL for `prisma migrate`.
DATABASE_URL=postgresql://user:pass@host-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://user:pass@host.region.aws.neon.tech/neondb?sslmode=require

# Optional — base URL used in email links & webhook self-reference.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — Google Drive (preferred storage for letter attachments).
# Service account JSON (the full contents of the .json key file you download
# from IAM → Service Accounts → Keys → Create new key → JSON). The Drive
# folder referenced by GOOGLE_DRIVE_PARENT_FOLDER_ID must be shared to the
# service account's `client_email` with Editor access.
# When either var is missing, uploads fall back to Vercel Blob, then inline.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# Optional — Vercel Blob (legacy fallback when Google Drive is not configured).
# When all storage backends are missing, uploads fall back to inline base64 (max 2MB).
BLOB_READ_WRITE_TOKEN=

# Optional — Resend (email notifications for incoming letters & dispositions).
# When missing, email events are logged to the server console.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional — Outbound webhook target (e.g. n8n) for letter/disposition events.
# When N8N_WEBHOOK_URL is empty, delivery rows are still recorded but HTTP
# POST is skipped.
N8N_WEBHOOK_URL=
WEBHOOK_SIGNING_SECRET=change-this-to-another-long-random-string
